<Window x:Class="MURDOC_2024.Views.SessionHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session History"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="300"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="3*" MinWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== LEFT PANE: Session List ==================== -->
        <Border Grid.Column="0" 
                Background="White" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1" 
                CornerRadius="4">
            <DockPanel>
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Background="#E3F2FD" Margin="0,0,0,0">
                    <TextBlock Text="📋 Past Sessions" 
                               FontWeight="Bold" 
                               FontSize="14" 
                               Margin="12,10,12,8"/>
                    <TextBlock x:Name="SessionCountLabel" 
                               Text="0 sessions found" 
                               FontSize="11" 
                               Foreground="#666666"
                               Margin="12,0,12,8"/>
                </StackPanel>

                <!-- Session DataGrid -->
                <DataGrid x:Name="SessionGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="SessionGrid_SelectionChanged"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#FAFAFA"
                          RowBackground="White"
                          BorderThickness="0"
                          CanUserSortColumns="True"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          FontSize="11"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" 
                                            Binding="{Binding Date}" 
                                            Width="90"
                                            SortDirection="Descending"/>
                        <DataGridTextColumn Header="Time" 
                                            Binding="{Binding Time}" 
                                            Width="65"/>
                        <DataGridTextColumn Header="Duration" 
                                            Binding="{Binding Duration}" 
                                            Width="65"/>
                        <DataGridTextColumn Header="Images" 
                                            Binding="{Binding ImagesAnalyzed}" 
                                            Width="55"/>
                        <DataGridTextColumn Header="Edits" 
                                            Binding="{Binding TotalEdits}" 
                                            Width="45"/>
                        <DataGridTextColumn Header="Feedback" 
                                            Binding="{Binding TotalFeedback}" 
                                            Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" 
                      Width="6" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Stretch"
                      Background="Transparent"/>

        <!-- ==================== RIGHT PANE: Session Details ==================== -->
        <Border Grid.Column="2" 
                Background="White" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1" 
                CornerRadius="4">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="#E8F5E9">
                    <TextBlock x:Name="DetailHeader" 
                               Text="Select a session to view details" 
                               FontWeight="Bold" 
                               FontSize="14" 
                               Margin="12,10,12,8"/>
                </Border>

                <!-- No selection placeholder -->
                <TextBlock x:Name="NoSelectionLabel"
                           Text="← Select a session from the list to view its details and images."
                           FontSize="13"
                           Foreground="#999999"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="40"/>

                <!-- Detail content (hidden until selection) -->
                <ScrollViewer x:Name="DetailPanel" 
                              Visibility="Collapsed" 
                              VerticalScrollBarVisibility="Auto"
                              Padding="12">
                    <StackPanel>

                        <!-- Session Overview Stats -->
                        <Border Background="#F5F5F5" 
                                CornerRadius="4" 
                                Padding="12" 
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock x:Name="StatDuration" 
                                               Text="00:00:00" 
                                               FontSize="20" 
                                               FontWeight="Bold" 
                                               Foreground="#1565C0"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Duration" 
                                               FontSize="10" 
                                               Foreground="#888888"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock x:Name="StatImages" 
                                               Text="0" 
                                               FontSize="20" 
                                               FontWeight="Bold" 
                                               Foreground="#2E7D32"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Images" 
                                               FontSize="10" 
                                               Foreground="#888888"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock x:Name="StatFeedback" 
                                               Text="0" 
                                               FontSize="20" 
                                               FontWeight="Bold" 
                                               Foreground="#E65100"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Feedback" 
                                               FontSize="10" 
                                               Foreground="#888888"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Feedback Breakdown -->
                        <Border Background="#FFF8E1" 
                                CornerRadius="4" 
                                Padding="10" 
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Detection Feedback" 
                                           FontWeight="Bold" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="StatConfirmed" Text="✓ 0 Confirmed" Foreground="#2E7D32" Margin="0,0,15,0" FontSize="11"/>
                                    <TextBlock x:Name="StatRejected" Text="✗ 0 Rejected" Foreground="#C62828" Margin="0,0,15,0" FontSize="11"/>
                                    <TextBlock x:Name="StatCorrections" Text="+ 0 Corrections" Foreground="#E65100" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Per-Image Details -->
                        <TextBlock Text="Images in Session" 
                                   FontWeight="Bold" 
                                   FontSize="13" 
                                   Margin="0,0,0,8"/>

                        <DataGrid x:Name="ImageGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionChanged="ImageGrid_SelectionChanged"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  AlternatingRowBackground="#FAFAFA"
                                  BorderBrush="#E0E0E0"
                                  BorderThickness="1"
                                  CanUserSortColumns="True"
                                  FontSize="11"
                                  MaxHeight="180"
                                  Margin="0,0,0,12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Image" Binding="{Binding ImageName}" Width="*"/>
                                <DataGridTextColumn Header="Mask" Binding="{Binding MaskEdited}" Width="45"/>
                                <DataGridTextColumn Header="Rank" Binding="{Binding RankEdited}" Width="45"/>
                                <DataGridTextColumn Header="d'" Binding="{Binding Sensitivity}" Width="40"/>
                                <DataGridTextColumn Header="β" Binding="{Binding ResponseBias}" Width="40"/>
                                <DataGridTextColumn Header="✓" Binding="{Binding Confirmed}" Width="30"/>
                                <DataGridTextColumn Header="✗" Binding="{Binding Rejected}" Width="30"/>
                                <DataGridTextColumn Header="+" Binding="{Binding Corrections}" Width="30"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Image Viewer -->
                        <TextBlock x:Name="ImageViewerHeader" 
                                   Text="Select an image above to preview" 
                                   FontWeight="Bold" 
                                   FontSize="13" 
                                   Margin="0,0,0,8"/>

                        <Grid x:Name="ImageViewerGrid" 
                              Visibility="Collapsed" 
                              Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Original Image -->
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="Original" 
                                           FontWeight="SemiBold" 
                                           FontSize="11" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,4"/>
                                <Border BorderBrush="#CCCCCC" 
                                        BorderThickness="1" 
                                        CornerRadius="2"
                                        Background="#EEEEEE"
                                        Height="160">
                                    <Image x:Name="OriginalImageView" 
                                           Stretch="Uniform" 
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                            </StackPanel>

                            <!-- Binary Mask -->
                            <StackPanel Grid.Column="1" Margin="2,0,2,0">
                                <TextBlock Text="Binary Mask (bi_gt)" 
                                           FontWeight="SemiBold" 
                                           FontSize="11" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,4"/>
                                <Border BorderBrush="#CCCCCC" 
                                        BorderThickness="1" 
                                        CornerRadius="2"
                                        Background="#EEEEEE"
                                        Height="160">
                                    <Image x:Name="BinaryMaskView" 
                                           Stretch="Uniform" 
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                            </StackPanel>

                            <!-- Rank Map -->
                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                <TextBlock Text="Rank Map (fix)" 
                                           FontWeight="SemiBold" 
                                           FontSize="11" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,4"/>
                                <Border BorderBrush="#CCCCCC" 
                                        BorderThickness="1" 
                                        CornerRadius="2"
                                        Background="#EEEEEE"
                                        Height="160">
                                    <Image x:Name="RankMapView" 
                                           Stretch="Uniform" 
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Image status label -->
                        <TextBlock x:Name="ImageStatusLabel" 
                                   Text="" 
                                   FontSize="10" 
                                   Foreground="#999999" 
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
