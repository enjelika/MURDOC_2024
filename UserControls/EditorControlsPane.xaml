<UserControl x:Class="MURDOC_2024.UserControls.EditorControlsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MURDOC_2024.UserControls"
             xmlns:converters="clr-namespace:MURDOC_2024.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="1045" d:DesignWidth="320">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisConverter"/>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <Border BorderBrush="#CCCCCC" 
            BorderThickness="1" 
            Background="White"
            CornerRadius="4">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">

                <!-- Unified Editing Section -->
                <Label Content="Interactive Editing" FontWeight="Bold" FontSize="13"/>

                <TextBlock Text="Edit both polygon mask and rank map:"
                   FontSize="12"
                   Foreground="#666666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

                <!-- Enter Edit Mode Button -->
                <Button Content="🖊️ Enter Edit Mode"
                    Command="{Binding EnterEditModeCommand}"
                    Margin="0,0,0,8"
                    Padding="8,10"
                    Background="#E3F2FD"
                    BorderBrush="#2196F3"
                    BorderThickness="2"
                    ToolTip="Enable polygon and rank map editing">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditModeActive}" Value="True">
                                    <Setter Property="Background" Value="#C8E6C9"/>
                                    <Setter Property="BorderBrush" Value="#4CAF50"/>
                                    <Setter Property="Content" Value="✓ Editing Active"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Polygon Point Editing (always visible, enabled when edit mode active) -->
                <Border Background="#F5F5F5"
                    Padding="8"
                    CornerRadius="3"
                    Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Polygon Editing:" 
                           FontWeight="Bold" 
                           FontSize="11" 
                           Margin="0,0,0,5"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" 
                                Content="➕ Add Points" 
                                Command="{Binding SetAddPointsModeCommand}"
                                IsEnabled="{Binding IsEditModeActive}"
                                Margin="0,0,3,0"
                                Background="{Binding IsAddPointsMode, Converter={StaticResource BoolToColorConverter}}"
                                ToolTip="Click on polygon to add new points"/>

                            <Button Grid.Column="1" 
                                Content="➖ Remove Points" 
                                Command="{Binding SetRemovePointsModeCommand}"
                                IsEnabled="{Binding IsEditModeActive}"
                                Margin="3,0,0,0"
                                Background="{Binding IsRemovePointsMode, Converter={StaticResource BoolToColorConverter}}"
                                ToolTip="Click on existing points to remove them"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Separator Margin="0,10,0,10" Background="#E0E0E0"/>

                <!-- Rank Map Editing Section (always visible, enabled when edit mode active) -->
                <Label Content="Rank Map Editing" 
                   FontWeight="Bold" 
                   FontSize="13"/>

                <TextBlock Text="Adjust camouflage strength values:"
                   FontSize="12"
                   Foreground="#666666"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

                <!-- Brush Mode Selection -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                        Content="➕ Increase"
                        Command="{Binding SetIncreaseBrushCommand}"
                        IsEnabled="{Binding IsEditModeActive}"
                        Margin="0,0,3,0"
                        Background="{Binding IsIncreaseBrushActive, Converter={StaticResource BoolToColorConverter}}"
                        ToolTip="Paint to increase camouflage weakness (make more detectable)"/>

                    <Button Grid.Column="1"
                        Content="➖ Decrease"
                        Command="{Binding SetDecreaseBrushCommand}"
                        IsEnabled="{Binding IsEditModeActive}"
                        Margin="3,0,0,0"
                        Background="{Binding IsDecreaseBrushActive, Converter={StaticResource BoolToColorConverter}}"
                        ToolTip="Paint to decrease camouflage weakness (make more hidden)"/>
                </Grid>

                <!-- Brush Size -->
                <Label Content="Brush Size:" 
                   FontSize="11" 
                   Padding="0,5,0,2"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                            Content="−" 
                            Width="25" 
                            Command="{Binding DecreaseBrushSizeCommand}"
                            IsEnabled="{Binding IsEditModeActive}"/>
                    <Slider Grid.Column="1" 
                        Value="{Binding BrushSize}"
                        Minimum="5" Maximum="100"
                        TickFrequency="5"
                        IsSnapToTickEnabled="True"
                        IsEnabled="{Binding IsEditModeActive}"
                        Margin="5,0"/>
                    <Button Grid.Column="2" 
                            Content="+" 
                            Width="25" 
                            Command="{Binding IncreaseBrushSizeCommand}"
                            IsEnabled="{Binding IsEditModeActive}"/>
                </Grid>

                <TextBlock HorizontalAlignment="Center" 
                   Margin="0,0,0,8">
                    <Run Text="Size: "/>
                    <Run Text="{Binding BrushSize}" FontWeight="Bold"/>
                    <Run Text="px"/>
                </TextBlock>

                <!-- Brush Strength -->
                <Label Content="Brush Strength:" 
                   FontSize="11" 
                   Padding="0,5,0,2"/>
                <Slider Value="{Binding BrushStrength}"
                    Minimum="0.1" Maximum="1.0"
                    TickFrequency="0.1"
                    IsSnapToTickEnabled="True"
                    IsEnabled="{Binding IsEditModeActive}"
                    Margin="0,0,0,5"/>

                <TextBlock HorizontalAlignment="Center" 
                       Margin="0,0,0,8">
                    <Run Text="Strength: "/>
                    <Run Text="{Binding BrushStrength, StringFormat='{}{0:P0}'}" FontWeight="Bold"/>
                </TextBlock>

                <!-- Save Button -->
                <Button Content="💾 Save Changes"
                    Command="{Binding SaveChangesCommand}"
                    IsEnabled="{Binding IsEditModeActive}"
                    Margin="0,0,0,5"
                    Padding="8,10"
                    Background="#E8F5E9"
                    BorderBrush="#4CAF50"
                    BorderThickness="2"
                    FontWeight="Bold"
                    ToolTip="Save modifications and exit edit mode (Right-click also exits)"/>

                <!-- Status Display -->
                <Border Background="#FFF3E0" 
                    Padding="8,5" 
                    CornerRadius="3"
                    Margin="0,0,0,10"
                    Visibility="{Binding IsEditModeActive, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock FontSize="11" 
                           Foreground="#E65100"
                           TextWrapping="Wrap">
                        <Run Text="⚠️ Editing Mode Active"/>
                        <LineBreak/>
                        <Run Text="Right-click to exit without saving"/>
                    </TextBlock>
                </Border>

                <Separator Margin="0,10,0,10" Background="#E0E0E0"/>

                <!-- Detection Feedback Section -->
                <Label Content="Detection Feedback" FontWeight="Bold" FontSize="13"/>

                <TextBlock Text="Select a detection to provide feedback"
                    FontSize="12"
                    Foreground="#666666"
                    TextWrapping="Wrap"
                    Margin="0,0,0,8"/>

                <!-- Current Selection Display -->
                <Border Background="#E3F2FD" 
                    Padding="8,5" 
                    CornerRadius="3"
                    Margin="0,0,0,8"
                    Visibility="{Binding HasSelectedDetection, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock FontSize="11" TextWrapping="Wrap">
                        <Run Text="Selected: " FontWeight="Bold"/>
                        <Run Text="{Binding SelectedDetectionLabel, Mode=OneWay}"/>
                        <LineBreak/>
                        <Run Text="Confidence: " FontWeight="Bold"/>
                        <Run Text="{Binding SelectedDetectionConfidence, StringFormat='{}{0:P2}', Mode=OneWay}"/>
                    </TextBlock>
                </Border>

                <!-- Feedback Action Buttons -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                        Command="{Binding ConfirmDetectionCommand}"
                        Margin="0,0,3,0"
                        Padding="8,10"
                        Background="#E8F5E9"
                        BorderBrush="#4CAF50"
                        BorderThickness="2"
                        ToolTip="Confirm this detection is correct">
                        <StackPanel>
                            <TextBlock Text="✓ Confirm" 
                      FontWeight="Bold" 
                      Foreground="#4CAF50"
                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1" 
                        Command="{Binding RejectDetectionCommand}"
                        Margin="3,0,0,0"
                        Padding="8,10"
                        Background="#FFEBEE"
                        BorderBrush="#F44336"
                        BorderThickness="2"
                        ToolTip="Reject this detection as incorrect">
                        <StackPanel>
                            <TextBlock Text="✗ Reject" 
                      FontWeight="Bold" 
                      Foreground="#F44336"
                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Add Correction Button -->
                <Button Command="{Binding EnableCorrectionModeCommand}"
                    Padding="8,10"
                    Margin="0,0,0,8"
                    Background="#FFF3E0"
                    BorderBrush="#FFB74D"
                    BorderThickness="2"
                    ToolTip="Draw polygon around object the system missed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="➕ " 
                  FontWeight="Bold" 
                  Foreground="#FF9800"
                  FontSize="14"
                  VerticalAlignment="Center"/>
                        <TextBlock Text="Add Missed Object" 
                  FontWeight="Bold" 
                  Foreground="#FF9800"
                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Feedback Stats (Read-only summary) -->
                <Border Background="#F0F0F0" 
                    Padding="8" 
                    CornerRadius="3"
                    Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="✓" 
                      Foreground="#4CAF50" 
                      FontWeight="Bold"
                      FontSize="14"
                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ConfirmedCount, Mode=OneWay}" 
                      FontWeight="Bold"
                      FontSize="12"
                      HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="✗" 
                      Foreground="#F44336" 
                      FontWeight="Bold"
                      FontSize="14"
                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding RejectedCount, Mode=OneWay}" 
                      FontWeight="Bold"
                      FontSize="12"
                      HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="➕" 
                      Foreground="#FF9800" 
                      FontWeight="Bold"
                      FontSize="14"
                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding CorrectionCount, Mode=OneWay}" 
                      FontWeight="Bold"
                      FontSize="12"
                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button Content="📊 View Feedback History" 
                        Command="{Binding ViewFeedbackHistoryCommand}"
                        Margin="0,0,0,5"
                        Padding="8,10"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Background="#E3F2FD"
                        BorderBrush="#2196F3"
                        BorderThickness="2"
                        ToolTip="View summary of all detection feedback"/>

                <Button Content="💾 Export Feedback Data" 
                        Command="{Binding ExportFeedbackCommand}"
                        Margin="0,0,0,5"
                        Padding="8,10"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Background="#E8F5E9"
                        BorderBrush="#4CAF50"
                        BorderThickness="2"
                        ToolTip="Save feedback history as JSON"/>

                <Separator Margin="0,10,0,10" Background="#E0E0E0"/>

                <!-- Session Info -->
                <Label Content="Session Information" FontWeight="Bold" FontSize="13"/>

                <Border Background="#F5F5F5" 
                        Padding="8" 
                        CornerRadius="3"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock FontSize="11">
                            <Run Text="Total Interactions: "/>
                            <Run Text="{Binding TotalInteractions, Mode=OneWay}" 
                                 FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Margin="0,3,0,0">
                            <Run Text="Session Start: "/>
                            <Run Text="{Binding SessionStartTime, StringFormat='HH:mm:ss'}" 
                                 FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Button Content="🔄 Reset Session" 
                        Command="{Binding ResetSessionCommand}"
                        Margin="0,0,0,0"
                        Padding="8,10"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Background="#FFEBEE"
                        BorderBrush="#F44336"
                        BorderThickness="2"
                        ToolTip="Clear all ROIs and feedback"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>