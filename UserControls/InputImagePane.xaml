<UserControl x:Class="MURDOC_2024.UserControls.InputImagePane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MURDOC_2024.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="275" d:DesignWidth="300">
    <Grid>
        <StackPanel Orientation="Vertical" Background="Lightgray" Margin="5" Height="245">
            <!-- Bigger label with increased font size -->
            <Label Content="Input" 
                   FontWeight="Bold" 
                   FontSize="16"
                   Padding="5,8,5,5"/>

            <!-- Bigger image display -->
            <Image Source="{Binding InputImage}" 
                   Margin="5" 
                   Stretch="Uniform" 
                   Width="Auto" 
                   MaxHeight="240" />
        </StackPanel>
    </Grid>
</UserControl>