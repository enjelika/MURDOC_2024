<UserControl x:Class="MURDOC_2024.UserControls.ImageControlPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MURDOC_2024.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="320">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="5,5,5,0" Background="Lightgray">

            <!-- Image file select/browse button and text box -->
            <Label Content="Select Image:" FontWeight="Bold" FontSize="13"/>

            <StackPanel Orientation="Vertical" Margin="5,-5,5,5">
                <TextBox Text="{Binding SelectedImagePath, Mode=OneWay}" 
                         TextWrapping="NoWrap" 
                         MinWidth="200" 
                         Width="Auto" 
                         Margin="5,5,5,8" 
                         IsReadOnly="True" 
                         FontSize="16"/>

                <!-- Browse Button - Big and prominent -->
                <Button Content="📁 Browse" 
                        Command="{Binding BrowseCommand}" 
                        Margin="5,0,5,10"
                        Padding="8,10"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Background="#E3F2FD"
                        BorderBrush="#2196F3"
                        BorderThickness="2"
                        ToolTip="Select an image file to analyze"/>
            </StackPanel>

            <!-- Image Adjustment Controls -->
            <Label Content="Image Adjustments:" FontWeight="Bold" FontSize="13" Margin="5,-5,5,5"/>

            <!-- Brightness -->
            <Border Background="White" 
                    CornerRadius="3" 
                    Padding="8" 
                    Margin="5,0,5,8">
                <StackPanel>
                    <TextBlock Text="Brightness" FontWeight="SemiBold" FontSize="12"/>
                    <DockPanel Margin="0,5,0,0">
                        <TextBox Text="{Binding ElementName=sliderBrightness, Path=Value, UpdateSourceTrigger=PropertyChanged}" 
                                 DockPanel.Dock="Right" 
                                 TextAlignment="Center" 
                                 Width="40" 
                                 FontSize="11"
                                 VerticalAlignment="Center"/>
                        <Slider Minimum="-100" 
                                Maximum="100" 
                                TickFrequency="5" 
                                IsSnapToTickEnabled="True" 
                                Name="sliderBrightness" 
                                Value="{Binding SliderBrightness}" 
                                IsEnabled="{Binding IsSlidersEnabled}"
                                Margin="0,0,5,0"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Contrast -->
            <Border Background="White" 
                    CornerRadius="3" 
                    Padding="8" 
                    Margin="5,0,5,8">
                <StackPanel>
                    <TextBlock Text="Contrast" FontWeight="SemiBold" FontSize="12"/>
                    <DockPanel Margin="0,5,0,0">
                        <TextBox Text="{Binding ElementName=sliderContrast, Path=Value, UpdateSourceTrigger=PropertyChanged}" 
                                 DockPanel.Dock="Right" 
                                 TextAlignment="Center" 
                                 Width="40" 
                                 FontSize="11"
                                 VerticalAlignment="Center"/>
                        <Slider Minimum="-100" 
                                Maximum="100" 
                                TickFrequency="5" 
                                IsSnapToTickEnabled="True" 
                                Name="sliderContrast" 
                                Value="{Binding SliderContrast}" 
                                IsEnabled="{Binding IsSlidersEnabled}"
                                Margin="0,0,5,0"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Saturation -->
            <Border Background="White" 
                    CornerRadius="3" 
                    Padding="8" 
                    Margin="5,0,5,8">
                <StackPanel>
                    <TextBlock Text="Saturation" FontWeight="SemiBold" FontSize="12"/>
                    <DockPanel Margin="0,5,0,0">
                        <TextBox Text="{Binding ElementName=sliderSaturation, Path=Value, UpdateSourceTrigger=PropertyChanged}" 
                                 DockPanel.Dock="Right" 
                                 TextAlignment="Center" 
                                 Width="40" 
                                 FontSize="11"
                                 VerticalAlignment="Center"/>
                        <Slider Minimum="-100" 
                                Maximum="100" 
                                TickFrequency="5" 
                                IsSnapToTickEnabled="True" 
                                Name="sliderSaturation" 
                                Value="{Binding SliderSaturation}" 
                                IsEnabled="{Binding IsSlidersEnabled}"
                                Margin="0,0,5,0"/>
                    </DockPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>