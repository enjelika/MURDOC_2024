<UserControl x:Class="MURDOC_2024.UserControls.SessionInfoPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MURDOC_2024.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="#F5F5F5" 
            BorderBrush="#CCCCCC" 
            BorderThickness="1" 
            CornerRadius="4"
            Padding="12">

        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Current Session" 
                       FontWeight="Bold" 
                       FontSize="14"
                       Margin="0,0,0,10"/>

            <Separator Margin="0,0,0,10" Background="#E0E0E0"/>

            <!-- Session Info (visible when active) -->
            <StackPanel Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVisConverter}}">

                <!-- Image Name -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="📷" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock Text="Image: " FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="{Binding CurrentImageName}" 
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding CurrentImageName}"/>
                </StackPanel>

                <!-- Duration -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="⏱️" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock Text="Duration: " FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="{Binding SessionDuration}" 
                               FontSize="12"
                               FontFamily="Consolas"/>
                </StackPanel>

                <!-- Modifications -->
                <TextBlock Text="Modifications:" 
                           FontWeight="SemiBold" 
                           FontSize="12"
                           Margin="0,0,0,5"/>

                <StackPanel Margin="15,0,0,0">
                    <!-- Binary Mask Status -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="{Binding HasBinaryMaskEdits, Converter={StaticResource BoolToCheckmarkConverter}}" 
                                   FontSize="12" 
                                   Margin="0,0,5,0"
                                   Foreground="{Binding HasBinaryMaskEdits, Converter={StaticResource BoolToEditColorConverter}}"/>
                        <TextBlock Text="Binary Mask Edited" 
                                   FontSize="11"
                                   Foreground="{Binding HasBinaryMaskEdits, Converter={StaticResource BoolToEditColorConverter}}"/>
                    </StackPanel>

                    <!-- Rank Map Status -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="{Binding HasRankMapEdits, Converter={StaticResource BoolToCheckmarkConverter}}" 
                                   FontSize="12" 
                                   Margin="0,0,5,0"
                                   Foreground="{Binding HasRankMapEdits, Converter={StaticResource BoolToEditColorConverter}}"/>
                        <TextBlock Text="Rank Map Edited" 
                                   FontSize="11"
                                   Foreground="{Binding HasRankMapEdits, Converter={StaticResource BoolToEditColorConverter}}"/>
                    </StackPanel>
                </StackPanel>

                <!-- End Session Button -->
                <Button Content="📊 End Session &amp; Save"
                        Command="{Binding EndSessionCommand}"
                        Margin="0,15,0,0"
                        Padding="8,8"
                        Background="#E8F5E9"
                        BorderBrush="#4CAF50"
                        BorderThickness="2"
                        FontWeight="Bold"
                        FontSize="12"
                        ToolTip="Save modifications and end current session"/>
            </StackPanel>

            <!-- No Active Session Message -->
            <TextBlock Text="No active session" 
                       FontStyle="Italic" 
                       FontSize="12"
                       Foreground="#999999"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,20"
                       Visibility="{Binding HasActiveSession, Converter={StaticResource InverseBoolToVisConverter}}"/>

        </StackPanel>
    </Border>
</UserControl>
